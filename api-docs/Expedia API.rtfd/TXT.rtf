\fs32 \cf2 \cb3 \strokec2 TR2: Provide the traveler's country code with each request\cb1 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\partightenfactor0
\ls8\ilvl0
\fs24 \cf2 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 \uc0\u8232 \cb3 The traveler's\'a0
\f1\fs20\fsmilli10200 \cb8 country_code
\f0\fs24 \cb3 \'a0must be passed in API requests for Shopping and Recommendations. The country code must match the point of sale being accessed by the traveler.\cb1 \uc0\u8232 \u8232 \cb3 This requirement ensures our systems provide travelers with relevant content and the most suitable rates based on the sales market.
\fs32 \cb1 \
\pard\pardeftab720\partightenfactor0
\cf2 \cb3 Example API request:\cb1 \
\pard\pardeftab720\partightenfactor0

\f1\fs20\fsmilli10200 \cf3 \cb9 \strokec3 https://api.ean.com/2.4/properties/availability?checkin=2020-09-11\
&checkout=2020-09-14\
&currency=USD&language=en-US&occupancy=2-3,4&property_id=XXXX\
&country_code=XX&sales_channel=XXXX\
&sales_environment=XXXX&filter=XXXX&rate_plan_count=XXXX\
&rate_option=XXXX&billing_terms=XXXX&payment_terms=XXXX\
&partner_point_of_sale=XXXX&platform_name=XXXX\
\pard\pardeftab720\partightenfactor0

\f0\fs24 \cf3 \cb1 \
\pard\pardeftab720\partightenfactor0

\fs32 \cf2 \cb3 \strokec2 TR3: Provide billing information with each request\cb1 \
\cb3 A) Payor name\cb1 \
\cb3 For traveler, corporate, and virtual card:\cb1 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\partightenfactor0
\ls9\ilvl0
\fs24 \cf2 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 \uc0\u8232 \cb3 You must send the name of the cardholder whose card is being charged by us.
\fs32 \cb1 \
\pard\pardeftab720\partightenfactor0
\cf2 \cb3 For Affiliate Collect or EAC Partners:\cb1 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\partightenfactor0
\ls10\ilvl0
\fs24 \cf2 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 \uc0\u8232 \cb3 Wherever possible, Expedia Group strongly recommends that you send the name of the actual end payor for the booking.\cb1 \uc0\u8232 \u8232 \cb3 This information is required for regulatory/sanctions screening purposes.\cb1 \uc0\u8232 \u8232 \cb3 If it's not possible to provide the name of the actual end payor, provide the name of the company or legal entity that is paying us.
\fs32 \cb1 \
\pard\pardeftab720\partightenfactor0
\cf2 \cb3 Note:\'a0If the POS is Russia, Ukraine, or Venezuela then true payor information is always required.\cb1 \
\cb3 B) Billing country\cb1 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\partightenfactor0
\ls11\ilvl0
\fs24 \cf2 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 \uc0\u8232 \cb3 Must represent the individual name passed in the billing contact/payor name field.
\fs32 \cb1 \
\pard\pardeftab720\partightenfactor0
\cf2 \cb3 C) Billing ZIP code\cb1 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\partightenfactor0
\ls12\ilvl0
\fs24 \cf2 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 \uc0\u8232 \cb3 Must represent the individual name passed in the billing contact/payor name field.
\fs32 \cb1 \
\pard\pardeftab720\partightenfactor0
\cf2 \cb3 Note:\'a0For countries that do not maintain a ZIP code, this information does not need to be provided.\cb1 \
\cb3 Example:\cb1 \
\pard\pardeftab720\partightenfactor0

\f1\fs20\fsmilli10200 \cf3 \cb9 \strokec3 "payments": [\
   \{\
       "type": \cf10 \strokec10 "customer_card"\cf3 \strokec3 ,\
       "billing_contact": \{\
           "given_name": \cf10 \strokec10 "Launch_Requirement_TR3a"\cf3 \strokec3 ,\
           "family_name": \cf10 \strokec10 "Launch_Requirement_TR3a"\cf3 \strokec3 ,\
       "address": \{\
           "line_1": \cf10 \strokec10 "555 1st St"\cf3 \strokec3 ,\
           "line_2": \cf10 \strokec10 "10th Floor"\cf3 \strokec3 ,\
           "line_3": \cf10 \strokec10 "Unit 12"\cf3 \strokec3 ,\
           "city": \cf10 \strokec10 "Seattle"\cf3 \strokec3 ,\
           "state_province_code": \cf10 \strokec10 "WA"\cf3 \strokec3 ,\
           "postal_code": \cf10 \strokec10 "Launch_Requirement_TR3c"\cf3 \strokec3 ,\
           "country_code": \cf10 \strokec10 "Launch_Requirement_TR3b"\cf3 \strokec3 \
       \}\
   \},\
