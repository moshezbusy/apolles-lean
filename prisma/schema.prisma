// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  AGENT @map("agent")
  ADMIN @map("platform_admin")

  @@map("UserRole")
}

enum Supplier {
  TBO     @map("tbo")
  EXPEDIA @map("expedia")

  @@map("Supplier")
}

model User {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String          @unique
  name           String
  emailVerified  DateTime?       @map("email_verified")
  passwordHash   String          @map("password_hash")
  role           Role            @default(AGENT)
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  accounts       Account[]
  sessions       Session[]
  authenticators Authenticator[]
  updatedPlatformSettings PlatformSetting[] @relation("PlatformSettingUpdatedBy")

  @@map("users")
}

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String   @map("updated_by") @db.Uuid

  updatedByUser User @relation("PlatformSettingUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict)

  @@map("platform_settings")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Authenticator {
  credentialID         String  @unique @map("credential_id")
  userId               String  @map("user_id") @db.Uuid
  providerAccountId    String  @map("provider_account_id")
  credentialPublicKey  String  @map("credential_public_key")
  counter              Int
  credentialDeviceType String  @map("credential_device_type")
  credentialBackedUp   Boolean @map("credential_backed_up")
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
  @@map("authenticators")
}

model SupplierApiLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplier       Supplier
  method         String
  endpoint       String
  requestBody    Json?    @map("request_body")
  responseBody   Json?    @map("response_body")
  responseStatus Int?     @map("response_status")
  durationMs     Int      @map("duration_ms")
  errorMessage   String?  @map("error_message")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("supplier_api_logs")
}
